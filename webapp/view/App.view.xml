<mvc:View controllerName="distributor.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns="sap.m">
    
    <html:div class="flex flex-col h-full relative overflow-hidden font-sans text-slate-800">
        
        <!-- BRAND MAIN BACKGROUND ARCH DESIGN OVERLAY -->
        <html:div class="absolute top-0 left-0 right-0 h-44 bg-gradient-to-b from-[#fcebd9] to-[#ffffff] rounded-b-[40px] -z-10"></html:div>
        
        <!-- APP HEADER SECTION -->
        <html:div class="px-5 py-3 flex justify-between items-center bg-transparent shrink-0">
          <html:div class="flex items-center gap-3">
            <html:div class="w-12 h-12 rounded-full shadow-md flex items-center justify-center overflow-hidden shrink-0 bg-white">
              <html:img src="images/sauda_logo.png" class="w-full h-full object-cover" alt="Sauda Logo" />
            </html:div>
            
            <html:div class="flex flex-col">
              <html:div class="flex items-center gap-1">
                <html:div class="w-7 h-7 rounded-full bg-slate-300 flex items-center justify-center overflow-hidden">
                  <html:svg class="w-5 h-5 text-slate-500" fill="currentColor" viewBox="0 0 24 24">
                    <html:path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                  </html:svg>
                </html:div>
                <html:div>
                  <html:h4 class="text-xs font-bold text-slate-900 leading-tight">Rohan Shelar</html:h4>
                  <Text text="{/currentTime}" class="text-[9px] text-slate-500 font-medium block" />
                </html:div>
              </html:div>
            </html:div>
          </html:div>

          <html:button class="relative w-9 h-9 rounded-full bg-white shadow-sm flex items-center justify-center text-slate-600 hover:bg-orange-50 transition-colors">
            <html:svg class="w-5 h-5 text-[#f37a20]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <html:path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </html:svg>
            <html:span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full ring-2 ring-white"></html:span>
          </html:button>
        </html:div>

        <!-- ROUTER OUTLET -->
        <html:div class="flex-1 overflow-y-auto px-4 pb-20 scrollbar-none relative">
            <App id="app" class="bg-transparent h-full relative"></App>
        </html:div>

        <!-- CUSTOM INTERACTIVE MODALS -->
        <core:HTML xmlns:core="sap.ui.core" content="{path: '/activeModal', formatter: '.formatModal'}" />

        <!-- STICKY BOTTOM NAVIGATION BAR -->
        <html:div class="absolute bottom-0 left-0 right-0 h-16 bg-white border-t border-slate-100 flex justify-around items-center px-2 py-1 shadow-lg z-50 shrink-0">
          <core:HTML xmlns:core="sap.ui.core" content="{path: '/selectedNavTab', formatter: '.formatBottomNav'}" />
        </html:div>
    </html:div>
</mvc:View>