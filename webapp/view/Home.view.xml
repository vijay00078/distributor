<mvc:View controllerName="distributor.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns="sap.m">
    <Page showHeader="false" backgroundDesign="Transparent" class="bg-transparent">
        <html:div class="pt-2 space-y-4 animate-fade-in">
            
            <!-- Distributor Filter Dropdown -->
            <html:div class="relative bg-white rounded-xl border border-slate-200 px-4 py-2 mt-2 shadow-2xs hover:border-[#f37a20] focus-within:border-black transition-colors">
              <html:span class="absolute -top-2 left-3 bg-[#ffffff] px-1 text-[10px] text-[#f37a20] font-bold tracking-wider">Distributor Name</html:span>
              <Select 
                width="100%"
                class="custom-select-no-border w-full bg-transparent text-sm font-bold text-slate-800 outline-none pr-8 cursor-pointer"
                selectedKey="{/selectedDistributor}"
                items="{/distributorList}"
                change=".onDistributorChange"
              >
                <core:Item xmlns:core="sap.ui.core" key="{}" text="{}" />
              </Select>
            </html:div>

            <!-- Sauda & Sales Tabs (Pills) -->
            <html:div class="flex bg-white p-1 rounded-2xl shadow-3xs border border-slate-100">
               <core:HTML sanitizeContent="false" xmlns:core="sap.ui.core" content="{path: '/selectedSaudaSalesTab', formatter: '.formatSaudaSalesTabs'}" />
            </html:div>

            <!-- Target and Achievement Progress Panel -->
            <html:div class="bg-white rounded-2xl p-4 shadow-xs border border-slate-100 relative overflow-hidden">
              <html:div class="flex justify-between items-start mb-3">
                <html:div>
                  <html:div class="flex items-center gap-1.5">
                    <html:span class="text-xs font-bold text-slate-500 uppercase tracking-wider">Overall </html:span>
                    <Text text="{/selectedSaudaSalesTab}" class="text-xs font-bold text-slate-500 uppercase tracking-wider" />
                    <Text text="{= ${/selectedDistributor} === 'All Distributor' ? '(Total)' : '(Unit)'}" class="text-xs text-slate-400 font-medium ml-1" />
                  </html:div>
                  <html:div class="flex items-baseline gap-2 mt-1">
                    <Text text="{/activeSaudaMetrics/achievement} {= ${/selectedSaudaSalesTab} === 'Sauda' ? 'MT' : 'L'}" class="text-lg font-black text-[#f37a20]" />
                    <Text text="/ {/activeSaudaMetrics/target} {= ${/selectedSaudaSalesTab} === 'Sauda' ? 'MT' : 'L'} Target" class="text-xs text-slate-500 font-bold ml-1" />
                  </html:div>
                </html:div>

                <!-- MTD / QTD / YTD Filters -->
                <html:div class="flex bg-slate-100 p-0.5 rounded-lg border border-slate-200">
                    <core:HTML sanitizeContent="false" xmlns:core="sap.ui.core" content="{path: '/selectedTimeframe', formatter: '.formatTimeframeFilters'}" />
                </html:div>
              </html:div>

              <!-- Dynamic Progress bar -->
              <html:div class="w-full bg-slate-100 h-2.5 rounded-full overflow-hidden mb-5">
                <html:div 
                  class="h-full bg-gradient-to-r from-[#fab915] to-[#f37a20] rounded-full transition-all duration-500"
                  style="width: {path: '/activeSaudaMetrics', formatter: '.formatProgressBarWidth'}"
                ></html:div>
              </html:div>

              <!-- Interactive SVG Weekly bar charts (Week 1 to Week 4) -->
              <html:div class="relative mt-2">
                <html:div class="flex justify-between items-end h-32 pt-4 relative" id="weeklyChartContainer">
                  <!-- Grid horizontal helper lines -->
                  <html:div class="absolute inset-x-0 bottom-0 border-b border-slate-100 w-full"></html:div>
                  <html:div class="absolute inset-x-0 bottom-8 border-b border-slate-100 w-full"></html:div>
                  <html:div class="absolute inset-x-0 bottom-16 border-b border-slate-100 w-full"></html:div>
                  <html:div class="absolute inset-x-0 bottom-24 border-b border-slate-100 w-full"></html:div>

                  <core:HTML sanitizeContent="false" xmlns:core="sap.ui.core" content="{path: '/activeSaudaMetrics', formatter: '.formatWeeklyChart'}" />
                </html:div>

                <!-- Chart Legend -->
                <html:div class="flex justify-center items-center gap-6 mt-4 pt-3 border-t border-slate-50">
                  <html:div class="flex items-center gap-2">
                    <html:span class="w-3.5 h-3.5 bg-[#0ca2db] rounded-sm"></html:span>
                    <html:span class="text-[11px] font-bold text-slate-600">Target</html:span>
                  </html:div>
                  <html:div class="flex items-center gap-2">
                    <html:span class="w-3.5 h-3.5 bg-[#85c441] rounded-sm"></html:span>
                    <html:span class="text-[11px] font-bold text-slate-600">Achievement</html:span>
                  </html:div>
                </html:div>
              </html:div>
            </html:div>

            <!-- Pending Sauda / Expired Section Layout -->
            <html:div class="bg-white rounded-2xl p-4 shadow-xs border border-slate-100 space-y-4">
              <html:div class="flex justify-between items-center pb-2 border-b border-slate-50">
                <html:h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider">Expired &amp; Near Expired</html:h3>
                <html:span class="text-[10px] text-slate-400 font-bold">Real-time stats</html:span>
              </html:div>

              <html:div class="grid grid-cols-2 gap-3">
                
                <html:div class="bg-[#eb3330] rounded-tl-[28px] rounded-br-[28px] rounded-tr-[4px] rounded-bl-[4px] p-3.5 text-white shadow-sm flex flex-col justify-between h-24 hover:scale-[1.02] transition-transform cursor-pointer">
                  <html:div class="flex justify-between items-start">
                    <Text text="{/activeSaudaMetrics/expired}" class="text-[14px] font-bold tracking-wide text-white" />
                    <html:div class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center">
                      <html:svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <html:path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                      </html:svg>
                    </html:div>
                  </html:div>
                  <html:div>
                    <html:span class="text-[10px] font-medium opacity-90 block">Expired</html:span>
                  </html:div>
                </html:div>

                <html:div class="bg-[#f49326] rounded-tl-[28px] rounded-br-[28px] rounded-tr-[4px] rounded-bl-[4px] p-3.5 text-white shadow-sm flex flex-col justify-between h-24 hover:scale-[1.02] transition-transform cursor-pointer">
                  <html:div class="flex justify-between items-start">
                    <Text text="{/activeSaudaMetrics/nearExpired}" class="text-[14px] font-bold tracking-wide text-white" />
                    <html:div class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center">
                      <html:svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.1" viewBox="0 0 24 24">
                        <html:path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </html:svg>
                    </html:div>
                  </html:div>
                  <html:div>
                    <html:span class="text-[10px] font-medium opacity-90 block">Near Expired</html:span>
                  </html:div>
                </html:div>

                <html:div onclick="window.homeApp.openTodayRateCalculator()" class="bg-[#0598d1] rounded-tl-[28px] rounded-br-[28px] rounded-tr-[4px] rounded-bl-[4px] p-3.5 text-white shadow-sm flex flex-col justify-between h-24 hover:scale-[1.02] transition-transform cursor-pointer">
                  <html:div class="flex justify-between items-start">
                    <html:span class="text-[14px] font-bold tracking-wide">Today's Rate</html:span>
                    <html:div class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center font-bold text-sm text-white">
                      ₹
                    </html:div>
                  </html:div>
                  <html:div>
                    <Text text="{/activeSaudaMetrics/todaysRate}" class="text-[10px] font-medium opacity-90 block text-white" />
                  </html:div>
                </html:div>

                <html:div class="bg-[#e7a726] rounded-tl-[28px] rounded-br-[28px] rounded-tr-[4px] rounded-bl-[4px] p-3.5 text-white shadow-sm flex flex-col justify-between h-24 hover:scale-[1.02] transition-transform cursor-pointer">
                  <html:div class="flex justify-between items-start">
                    <Text text="{/activeSaudaMetrics/pendingSauda}" class="text-[14px] font-bold tracking-wide text-white" />
                    <html:div class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center">
                      <html:svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.1" viewBox="0 0 24 24">
                        <html:path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </html:svg>
                    </html:div>
                  </html:div>
                  <html:div>
                    <html:span class="text-[10px] font-medium opacity-90 block">Pending Sauda</html:span>
                  </html:div>
                </html:div>

                <html:div class="bg-[#eb3330] rounded-tl-[28px] rounded-br-[28px] rounded-tr-[4px] rounded-bl-[4px] p-3.5 text-white shadow-sm flex flex-col justify-between h-24 hover:scale-[1.02] transition-transform cursor-pointer">
                  <html:div class="flex justify-between items-start">
                    <html:span class="text-[10px] font-medium opacity-90 block">Over Due</html:span>
                    <html:div class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center font-bold text-xs text-white">
                      ₹
                    </html:div>
                  </html:div>
                  <html:div>
                    <Text text="{/activeSaudaMetrics/overDue}" class="text-[13px] font-black tracking-tight text-white block" />
                  </html:div>
                </html:div>

                <html:div class="bg-[#f49326] rounded-tl-[28px] rounded-br-[28px] rounded-tr-[4px] rounded-bl-[4px] p-3.5 text-white shadow-sm flex flex-col justify-between h-24 hover:scale-[1.02] transition-transform cursor-pointer">
                  <html:div class="flex justify-between items-start">
                    <html:span class="text-[10px] font-medium opacity-90 block">Tomorrow Due</html:span>
                    <html:div class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center font-bold text-xs text-white">
                      ₹
                    </html:div>
                  </html:div>
                  <html:div>
                    <Text text="{/activeSaudaMetrics/tomorrowDue}" class="text-[13px] font-black tracking-tight text-white block" />
                  </html:div>
                </html:div>

              </html:div>
            </html:div>

            <!-- Quick Nav Links: Customer Ledger and Call to Customer -->
            <html:div class="space-y-2.5">
              <html:button onclick="window.homeApp.navToLedger()" class="w-full bg-white p-4 rounded-2xl border border-slate-100 shadow-3xs hover:border-[#f37a20] transition-all flex justify-between items-center cursor-pointer group block">
                <html:div class="flex items-center gap-3">
                  <html:div class="w-9 h-9 rounded-xl bg-orange-50 flex items-center justify-center text-[#f37a20]">
                    <html:svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <html:path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                    </html:svg>
                  </html:div>
                  <html:span class="text-sm font-bold text-slate-800">Customer Ledger</html:span>
                </html:div>
                <html:svg class="w-5 h-5 text-[#f37a20] group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <html:path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </html:svg>
              </html:button>

              <html:button onclick="window.homeApp.initiateCall()" class="w-full bg-white p-4 rounded-2xl border border-slate-100 shadow-3xs hover:border-[#f37a20] transition-all flex justify-between items-center cursor-pointer group block">
                <html:div class="flex items-center gap-3">
                  <html:div class="w-9 h-9 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                    <html:svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <html:path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.802-5.161-4.138-6.963-6.963l1.302-.97c.36-.271.525-.733.417-1.173L6.963 3.107a1.248 1.248 0 00-1.173-.935H3.107a2.25 2.25 0 00-2.25 2.25v2.25z" />
                    </html:svg>
                  </html:div>
                  <html:span class="text-sm font-bold text-slate-800">Call to Customer</html:span>
                </html:div>
                <html:svg class="w-5 h-5 text-[#f37a20] group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <html:path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </html:svg>
              </html:button>
            </html:div>

        </html:div>
    </Page>
</mvc:View>
